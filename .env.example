# Telegram bot token from @BotFather
BOT_TOKEN=123456:replace_me

# Chat ID of manager/admin where leads will be sent
MANAGER_CHAT_ID=-1001234567890

# Public links
CLINIC_SITE_URL=https://example-clinic.com
LOYALTY_BOT_USERNAME=loyalty_bot
LOYALTY_START_PREFIX=user_

# PostgreSQL settings (docker-compose uses port 5123)
POSTGRES_DB=marulidi_bot
POSTGRES_USER=marulidi
POSTGRES_PASSWORD=marulidi_password
POSTGRES_PORT=5123

# For docker-compose use host `db`, for local run change to `localhost`
DATABASE_URL=postgresql+asyncpg://marulidi:marulidi_password@db:5123/marulidi_bot

# Local guide files (PDF)
GUIDE_INSTAGRAM_PATH=./guides/instagram-guide.pdf
GUIDE_YOUTUBE_PATH=./guides/youtube-guide.pdf
GUIDE_DEFAULT_PATH=./guides/universal-guide.pdf

# Salt for phone hashing (required)
PHONE_HASH_SALT=replace_with_long_random_secret
